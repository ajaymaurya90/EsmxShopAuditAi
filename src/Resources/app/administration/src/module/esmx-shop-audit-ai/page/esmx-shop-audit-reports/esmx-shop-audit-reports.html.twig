{% block esmx_shop_audit_reports %}
    <sw-page class="esmx-shop-audit-reports">
        <template #smart-bar-header>
            <h2>{{ pageTitle }}</h2>
        </template>

        <template #smart-bar-actions>
            <mt-button size="default" @click="goToDashboard">
                {{ $tc('esmx-shop-audit-ai.navigation.dashboard') }}
            </mt-button>

            <mt-button size="default" @click="goToFindings">
                {{ $tc('esmx-shop-audit-ai.navigation.findings') }}
            </mt-button>

            <mt-button size="default" @click="goToTasks">
                {{ $tc('esmx-shop-audit-ai.navigation.tasks') }}
            </mt-button>

            <mt-button variant="primary" size="default">
                {{ $tc('esmx-shop-audit-ai.navigation.reports') }}
            </mt-button>

            <mt-button size="default" @click="goToSettings">
                {{ $tc('esmx-shop-audit-ai.navigation.settings') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isLoading || isRunningScan"
                    @click="loadReports"
            >
                {{ $tc('esmx-shop-audit-ai.general.refresh') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isRunningScan"
                    @click="runScan"
            >
                <span v-if="isRunningScan">{{ $tc('esmx-shop-audit-ai.dashboard.runningScanButton') }}</span>
                <span v-else>{{ $tc('esmx-shop-audit-ai.dashboard.runScanButton') }}</span>
            </mt-button>
        </template>

        <template #content>
            <sw-card-view>
                <template v-if="loadError">
                    <mt-banner variant="danger">
                        {{ loadError }}
                    </mt-banner>
                </template>

                <template v-if="scanError">
                    <mt-banner variant="danger">
                        {{ scanError }}
                    </mt-banner>
                </template>

                <mt-card>
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.reports.historyHeadline') }}
                    </template>

                    <template v-if="reports.length">
                        <sw-data-grid
                                :dataSource="reports"
                                :columns="reportColumns"
                                @row-click="loadReportDetail($event.id)"
                        />
                    </template>
                    <template v-else>
                        <p>{{ $tc('esmx-shop-audit-ai.reports.emptyState') }}</p>
                    </template>
                </mt-card>

                <mt-card v-if="selectedReport" class="esmx-shop-audit-dashboard__latest-scan-card">
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.reports.detailHeadline') }}
                    </template>

                    <div class="esmx-shop-audit-dashboard__latest-scan-meta">
                        <p>
                            {{ $tc('esmx-shop-audit-ai.dashboard.scanStatus') }}:
                            <strong>{{ selectedReport.status }}</strong>
                        </p>
                        <p>
                            {{ $tc('esmx-shop-audit-ai.reports.columns.scannedProducts') }}:
                            <strong>{{ selectedReport.scannedProducts }}</strong>
                        </p>
                        <p>
                            {{ $tc('esmx-shop-audit-ai.reports.columns.totalFindings') }}:
                            <strong>{{ selectedReport.totalFindings }}</strong>
                        </p>
                        <p>
                            {{ $tc('esmx-shop-audit-ai.reports.columns.highPriorityFindings') }}:
                            <strong>{{ selectedReport.highPriorityFindings }}</strong>
                        </p>
                    </div>
                </mt-card>

                <mt-card v-if="selectedFindings.length">
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.reports.findingsHeadline') }}
                    </template>

                    <sw-data-grid
                            :dataSource="selectedFindings"
                            :columns="findingColumns"
                    />
                </mt-card>

                <mt-card v-if="selectedTasks.length">
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.reports.tasksHeadline') }}
                    </template>

                    <sw-data-grid
                            :dataSource="selectedTasks"
                            :columns="taskColumns"
                    />
                </mt-card>
            </sw-card-view>
        </template>
    </sw-page>
{% endblock %}