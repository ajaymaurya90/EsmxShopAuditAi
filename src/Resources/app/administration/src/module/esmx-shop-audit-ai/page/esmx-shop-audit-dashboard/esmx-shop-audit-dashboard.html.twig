{% block esmx_shop_audit_dashboard %}
    <sw-page class="esmx-shop-audit-dashboard">
        <template #smart-bar-header>
            <h2>{{ $tc('esmx-shop-audit-ai.general.mainMenuItemGeneral') }}</h2>
        </template>

        <template #smart-bar-actions>
            <mt-button variant="primary" size="default">
                {{ $tc('esmx-shop-audit-ai.navigation.dashboard') }}
            </mt-button>

            <mt-button size="default" @click="goToFindings">
                {{ $tc('esmx-shop-audit-ai.navigation.findings') }}
            </mt-button>

            <mt-button size="default" @click="goToTasks">
                {{ $tc('esmx-shop-audit-ai.navigation.tasks') }}
            </mt-button>

            <mt-button
                    size="default"
                    :disabled="isLoading || isRunningScan"
                    @click="initializeDashboard"
            >
                <span>{{ $tc('esmx-shop-audit-ai.dashboard.refreshButton') }}</span>
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isRunningScan"
                    @click="runScan"
            >
                <span v-if="isRunningScan">{{ $tc('esmx-shop-audit-ai.dashboard.runningScanButton') }}</span>
                <span v-else>{{ $tc('esmx-shop-audit-ai.dashboard.runScanButton') }}</span>
            </mt-button>
        </template>

        <template #content>
            <sw-card-view>
                <template v-if="loadError">
                    <mt-banner variant="danger">
                        {{ loadError }}
                    </mt-banner>
                </template>

                <template v-else-if="dashboard">

                    <template v-if="scanError">
                        <mt-banner variant="danger">
                            {{ scanError }}
                        </mt-banner>
                    </template>

                    <mt-card v-if="latestScan" class="esmx-shop-audit-dashboard__latest-scan-card">
                        <template #headline>
                            {{ $tc('esmx-shop-audit-ai.dashboard.latestScanHeadline') }}
                        </template>

                        <div class="esmx-shop-audit-dashboard__latest-scan-meta">
                            <p>
                                {{ $tc('esmx-shop-audit-ai.dashboard.scanStatus') }}:
                                <strong>{{ latestScan.status }}</strong>
                            </p>
                            <p>
                                {{ $tc('esmx-shop-audit-ai.dashboard.scannedProducts') }}:
                                <strong>{{ latestScan.scannedProducts }}</strong>
                            </p>
                            <p>
                                {{ $tc('esmx-shop-audit-ai.dashboard.groupedFindings') }}:
                                <strong>{{ latestScan.totalFindings }}</strong>
                            </p>
                            <p>
                                {{ $tc('esmx-shop-audit-ai.dashboard.highPriorityFindings') }}:
                                <strong>{{ latestScan.highPriorityFindings }}</strong>
                            </p>
                        </div>
                    </mt-card>

                    <div class="esmx-shop-audit-dashboard__summary">
                        <div class="esmx-shop-audit-dashboard__summary-meta">
                            <div class="esmx-shop-audit-dashboard__headline">
                                <h3>{{ cardTitle }}</h3>
                                <p>
                                    {{ $tc('esmx-shop-audit-ai.dashboard.scannedProducts') }}:
                                    <strong>{{ meta.scannedProducts }}</strong>
                                    ·
                                    {{ $tc('esmx-shop-audit-ai.dashboard.totalIssues') }}:
                                    <strong>{{ totals.totalIssues }}</strong>
                                </p>
                            </div>
                        </div>

                        <div class="esmx-shop-audit-dashboard__summary-grid">
                            <a
                                    v-for="card in summaryCards"
                                    :key="card.key"
                                    href="#"
                                    class="esmx-shop-audit-dashboard__metric-card-link"
                                    @click.prevent="scrollToSection(card.target)"
                            >
                                <mt-card
                                        class="esmx-shop-audit-dashboard__metric-card"
                                        :class="getSeverityClass(card.severity)"
                                >
                                    <div class="esmx-shop-audit-dashboard__metric-card-horizontal">
                                        <div class="esmx-shop-audit-dashboard__metric-card-number-box">
                                            <span class="esmx-shop-audit-dashboard__metric-card-number">
                                                {{ card.count }}
                                            </span>
                                        </div>

                                        <div class="esmx-shop-audit-dashboard__metric-card-content">
                                            <div class="esmx-shop-audit-dashboard__metric-card-label">
                                                {{ card.label }}
                                            </div>

                                            <div class="esmx-shop-audit-dashboard__metric-card-footer">
        <span
                class="esmx-shop-audit-dashboard__severity-badge"
                :class="'severity-' + card.severity"
        >
            {{ getSeverityLabel(card.severity) }}
        </span>
                                            </div>
                                        </div>
                                    </div>
                                </mt-card>
                            </a>
                        </div>
                    </div>

                    <div
                            id="audit-section-missing-description"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingDescription') }}</span>

                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
            {{ $tc('esmx-shop-audit-ai.severity.medium') }}
        </span>
                                </div>
                            </template>

                            <template v-if="issues.missingDescription?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingDescription"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    <div
                            id="audit-section-missing-cover-image"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboard.missingCoverImage') }}
                            </template>

                            <template v-if="issues.missingCoverImage?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingCoverImage"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    <div
                            id="audit-section-inactive-products"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboard.inactiveProducts') }}
                            </template>

                            <template v-if="issues.inactiveProducts?.length">
                                <sw-data-grid
                                        :dataSource="issues.inactiveProducts"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    <div
                            id="audit-section-out-of-stock-products"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboard.outOfStockProducts') }}
                            </template>

                            <template v-if="issues.outOfStockProducts?.length">
                                <sw-data-grid
                                        :dataSource="issues.outOfStockProducts"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    <div
                            id="audit-section-missing-meta-title"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboard.missingMetaTitle') }}
                            </template>

                            <template v-if="issues.missingMetaTitle?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingMetaTitle"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>
                    <div
                            id="audit-section-missing-category"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingCategory') }}</span>

                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
                    {{ $tc('esmx-shop-audit-ai.severity.medium') }}
                </span>
                                </div>
                            </template>

                            <template v-if="issues.missingCategory?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingCategory"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    <div
                            id="audit-section-missing-manufacturer"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingManufacturer') }}</span>

                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
                    {{ $tc('esmx-shop-audit-ai.severity.medium') }}
                </span>
                                </div>
                            </template>

                            <template v-if="issues.missingManufacturer?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingManufacturer"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    <div
                            id="audit-section-missing-price"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingPrice') }}</span>

                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-high">
                    {{ $tc('esmx-shop-audit-ai.severity.high') }}
                </span>
                                </div>
                            </template>

                            <template v-if="issues.missingPrice?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingPrice"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    <div
                            id="audit-section-missing-translation"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingTranslation') }}</span>

                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
                    {{ $tc('esmx-shop-audit-ai.severity.medium') }}
                </span>
                                </div>
                            </template>

                            <template v-if="issues.missingTranslation?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingTranslation"
                                        :columns="translationGridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                </template>

                <template v-else>
                    <mt-card>
                        <p>{{ $tc('esmx-shop-audit-ai.dashboard.emptyState') }}</p>
                    </mt-card>
                </template>
            </sw-card-view>
        </template>
    </sw-page>
{% endblock %}