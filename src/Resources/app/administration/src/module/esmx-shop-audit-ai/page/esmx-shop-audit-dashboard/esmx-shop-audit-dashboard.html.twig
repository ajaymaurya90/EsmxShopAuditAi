{% block esmx_shop_audit_dashboard %}
    <sw-page class="esmx-shop-audit-dashboard">

        {# ------------------------------------------------------------------ #}
        {# Smart bar header section: Main page title                          #}
        {# ------------------------------------------------------------------ #}
        <template #smart-bar-header>
            <h2>{{ $tc('esmx-shop-audit-ai.general.mainMenuItemGeneral') }}</h2>
        </template>

        {# ------------------------------------------------------------------ #}
        {# Smart bar actions section: Navigation + page actions               #}
        {# ------------------------------------------------------------------ #}
        <template #smart-bar-actions>
            <mt-button variant="primary" size="default">
                {{ $tc('esmx-shop-audit-ai.navigation.dashboard') }}
            </mt-button>

            <mt-button size="default" @click="goToFindings">
                {{ $tc('esmx-shop-audit-ai.navigation.findings') }}
            </mt-button>

            <mt-button size="default" @click="goToTasks">
                {{ $tc('esmx-shop-audit-ai.navigation.tasks') }}
            </mt-button>

            <mt-button size="default" @click="goToReports">
                {{ $tc('esmx-shop-audit-ai.navigation.reports') }}
            </mt-button>

            <mt-button size="default" @click="goToSettings">
                {{ $tc('esmx-shop-audit-ai.navigation.settings') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isLoading || isRunningScan"
                    @click="initializeDashboard"
            >
                <span>{{ $tc('esmx-shop-audit-ai.general.refresh') }}</span>
            </mt-button>

            <div class="esmx-shop-audit-dashboard__actions">
                <mt-button
                        variant="primary"
                        size="default"
                        :loading="isRunningScan"
                        :disabled="isRunningScan"
                        @click="runScan"
                >
                    <span v-if="isRunningScan" class="esmx-shop-audit-dashboard__scan-status">
                    {{ $tc('esmx-shop-audit-ai.dashboard.scanRunning') }}
                </span>
                    <span v-else >
                    {{ $tc('esmx-shop-audit-ai.dashboard.scanStart') }}
                </span>
                </mt-button>


            </div>
        </template>

        {# ------------------------------------------------------------------ #}
        {# Main content section: All dashboard widgets and detail grids       #}
        {# ------------------------------------------------------------------ #}
        <template #content>
            <sw-card-view>

                {# ------------------------------------------------------------------ #}
                {# Global page error banner: Display dashboard load error              #}
                {# ------------------------------------------------------------------ #}
                <template v-if="loadError">
                    <mt-banner variant="danger">
                        {{ loadError }}
                    </mt-banner>
                </template>

                {# ------------------------------------------------------------------ #}
                {# Dashboard loaded state: Render all dashboard widgets                #}
                {# ------------------------------------------------------------------ #}
                <template v-else-if="dashboard">

                    {# ------------------------------------------------------------------ #}
                    {# Scan action error banner: Display scan execution error            #}
                    {# ------------------------------------------------------------------ #}
                    <template v-if="scanError">
                        <mt-banner variant="danger">
                            {{ scanError }}
                        </mt-banner>
                    </template>

                    <div class="esmx-shop-audit-dashboard__premium-top-grid">
                        <mt-card class="esmx-shop-audit-dashboard__health-card">
                            <div class="esmx-shop-audit-dashboard__health-card-inner">
                                <div class="esmx-shop-audit-dashboard__health-card-header">
                                    <div class="esmx-shop-audit-dashboard__health-card-title">
                                        {{ $tc('esmx-shop-audit-ai.dashboard.storeHealthTitle') }}
                                    </div>

                                    <div class="esmx-shop-audit-dashboard__health-card-status">
        <span
                class="esmx-shop-audit-dashboard__severity-badge"
                :class="'severity-' + healthStatus"
        >
            {{ healthStatusLabel }}
        </span>

                                        <span
                                                class="esmx-shop-audit-dashboard__widget-info-trigger"
                                                @mouseenter="activeWidgetTooltip = 'storeHealth'"
                                                @mouseleave="activeWidgetTooltip = null"
                                        >
            <mt-icon
                    name="regular-info-circle"
                    size="16px"
                    class="esmx-shop-audit-dashboard__widget-info-icon"
            />

            <span
                    v-if="activeWidgetTooltip === 'storeHealth'"
                    class="esmx-shop-audit-dashboard__widget-tooltip"
            >
                {{ $tc('esmx-shop-audit-ai.dashboard.storeHealthInfo') }}
            </span>
        </span>
                                    </div>
                                </div>

                                <div class="esmx-shop-audit-dashboard__health-score-row">
                                    <div
                                            class="esmx-shop-audit-dashboard__health-score-ring"
                                            :style="healthRingStyle"
                                    >
                                        <div class="esmx-shop-audit-dashboard__health-score-ring-inner">
                                            <div class="esmx-shop-audit-dashboard__health-score-value">
                                                {{ animatedHealthScore }}
                                            </div>
                                            <div class="esmx-shop-audit-dashboard__health-score-max">
                                                / 100
                                            </div>
                                        </div>
                                    </div>

                                    <div class="esmx-shop-audit-dashboard__health-score-text">
                                        <div class="esmx-shop-audit-dashboard__health-score-label">
                                            {{ healthStatusLabel }}
                                        </div>
                                        <div class="esmx-shop-audit-dashboard__health-score-summary">
                                            {{ healthSummaryText }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </mt-card>

                        <mt-card class="esmx-shop-audit-dashboard__quick-action-card">
                            <div class="esmx-shop-audit-dashboard__quick-action-header">
                                <div class="esmx-shop-audit-dashboard__quick-action-title">
                                    {{ $tc('esmx-shop-audit-ai.dashboard.nextBestActionTitle') }}
                                </div>
                            </div>

                            <div
                                    v-if="nextBestAction"
                                    class="esmx-shop-audit-dashboard__quick-action-body"
                            >
                                <div class="esmx-shop-audit-dashboard__quick-action-label">
                                    {{ nextBestAction.label }}
                                </div>

                                <div class="esmx-shop-audit-dashboard__quick-action-summary">
                                    {{ dashboardHeadline }}
                                </div>

                                <div
                                        v-if="formattedLatestScanDate"
                                        class="esmx-shop-audit-dashboard__quick-action-last-scan"
                                >
                                    {{ $tc('esmx-shop-audit-ai.dashboard.lastScanLabel') }}: {{ formattedLatestScanDate }}
                                </div>

                                <div class="esmx-shop-audit-dashboard__quick-action-footer">
                                    <mt-button
                                            size="small"
                                            variant="primary"
                                            @click="handleNextBestAction"
                                    >
                                        {{ $tc('esmx-shop-audit-ai.dashboard.reviewNow') }}
                                    </mt-button>
                                </div>
                            </div>

                            <div
                                    v-else
                                    class="esmx-shop-audit-dashboard__quick-action-body"
                            >
                                <div class="esmx-shop-audit-dashboard__quick-action-label">
                                    {{ $tc('esmx-shop-audit-ai.dashboard.healthyHeadline') }}
                                </div>

                                <div
                                        v-if="formattedLatestScanDate"
                                        class="esmx-shop-audit-dashboard__quick-action-last-scan"
                                >
                                    {{ $tc('esmx-shop-audit-ai.dashboard.lastScanLabel') }}: {{ formattedLatestScanDate }}
                                </div>
                            </div>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Insights widget grid: KPI metrics, top tasks, findings, summary   #}
                    {# ------------------------------------------------------------------ #}
                    <div class="esmx-shop-audit-dashboard__insights-grid">

                        {# ------------------------------------------------------------------ #}
                        {# KPI metrics widget: Audit overview                                #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card">
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboardInsights.auditOverviewHeadline') }}
                            </template>

                            <div class="esmx-shop-audit-dashboard__kpi-grid">
                                <div class="esmx-shop-audit-dashboard__kpi-item">
            <span class="esmx-shop-audit-dashboard__kpi-label">
                {{ $tc('esmx-shop-audit-ai.dashboardInsights.scannedProducts') }}
            </span>
                                    <strong class="esmx-shop-audit-dashboard__kpi-value">{{ latestScan?.scannedProducts || 0 }}</strong>
                                </div>

                                <div class="esmx-shop-audit-dashboard__kpi-item">
            <span class="esmx-shop-audit-dashboard__kpi-label">
                {{ $tc('esmx-shop-audit-ai.dashboardInsights.affectedProducts') }}
            </span>
                                    <strong class="esmx-shop-audit-dashboard__kpi-value">{{ affectedProducts }}</strong>
                                </div>

                                <div class="esmx-shop-audit-dashboard__kpi-item">
            <span class="esmx-shop-audit-dashboard__kpi-label">
                {{ $tc('esmx-shop-audit-ai.dashboardInsights.criticalIssues') }}
            </span>
                                    <strong class="esmx-shop-audit-dashboard__kpi-value">{{ criticalIssues }}</strong>
                                </div>

                                <div class="esmx-shop-audit-dashboard__kpi-item">
            <span class="esmx-shop-audit-dashboard__kpi-label">
                {{ $tc('esmx-shop-audit-ai.dashboardInsights.openTasks') }}
            </span>
                                    <strong class="esmx-shop-audit-dashboard__kpi-value">{{ openTaskCount }}</strong>
                                </div>
                            </div>
                        </mt-card>

                        {# ------------------------------------------------------------------ #}
                        {# Top tasks widget: Click-through list of highest priority tasks   #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card">
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboardInsights.topTasksHeadline') }}
                            </template>

                            <template v-if="topTasks.length">
                                <div
                                        v-for="task in topTasks"
                                        :key="task.id"
                                        class="esmx-shop-audit-dashboard__insight-list-item esmx-shop-audit-dashboard__insight-list-item--clickable"
                                        @click="goToTaskFilter(task)"
                                >
                                    <div>
                                        <div class="esmx-shop-audit-dashboard__insight-title">{{ task.title }}</div>
                                        <div class="esmx-shop-audit-dashboard__insight-meta">
                                            {{ task.priority }} · {{ task.status }}
                                        </div>
                                    </div>
                                    <strong>{{ task.affectedCount }}</strong>
                                </div>
                            </template>

                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboardInsights.emptyTasks') }}</p>
                            </template>
                        </mt-card>

                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Sales insights card: Revenue and order KPI summary                  #}
                    {# ------------------------------------------------------------------ #}
                    <mt-card class="esmx-shop-audit-dashboard__sales-card">
                        <div class="esmx-shop-audit-dashboard__widget-header">
                            <div class="esmx-shop-audit-dashboard__widget-header-text">
                                <div class="esmx-shop-audit-dashboard__widget-title">
                                    {{ $tc('esmx-shop-audit-ai.dashboard.salesInsightsHeadline') }}
                                </div>
                                <div class="esmx-shop-audit-dashboard__widget-subtitle">
                                    {{ $tc('esmx-shop-audit-ai.dashboard.salesInsightsSubtitle') }}
                                </div>
                            </div>

                            <span
                                    class="esmx-shop-audit-dashboard__widget-info-trigger"
                                    @mouseenter="activeWidgetTooltip = 'salesInsights'"
                                    @mouseleave="activeWidgetTooltip = null"
                            >
            <mt-icon
                    name="regular-info-circle"
                    size="16px"
                    class="esmx-shop-audit-dashboard__widget-info-icon"
            />

            <span
                    v-if="activeWidgetTooltip === 'salesInsights'"
                    class="esmx-shop-audit-dashboard__widget-tooltip"
            >
                {{ $tc('esmx-shop-audit-ai.dashboard.salesInsightsInfo') }}
            </span>
        </span>
                        </div>

                        <div class="esmx-shop-audit-dashboard__sales-kpis">
                            <div class="sales-kpi">
                                <span>{{ $tc('esmx-shop-audit-ai.dashboard.salesRevenue') }}</span>
                                <strong>{{ formatCurrency(salesKpis.revenue) }}</strong>
                            </div>

                            <div class="sales-kpi">
                                <span>{{ $tc('esmx-shop-audit-ai.dashboard.salesOrders') }}</span>
                                <strong>{{ salesKpis.orders }}</strong>
                            </div>

                            <div class="sales-kpi">
                                <span>{{ $tc('esmx-shop-audit-ai.dashboard.salesRevenueChange') }}</span>
                                <strong>{{ salesKpis.revenueChange.toFixed(1) }}%</strong>
                            </div>

                            <div class="sales-kpi">
                                <span>{{ $tc('esmx-shop-audit-ai.dashboard.salesOrdersChange') }}</span>
                                <strong>{{ salesKpis.ordersChange.toFixed(1) }}%</strong>
                            </div>
                        </div>
                    </mt-card>

                    {# ------------------------------------------------------------------ #}
                    {# Sales insight widgets: Top sellers and low stock product overview   #}
                    {# ------------------------------------------------------------------ #}
                    <div class="esmx-shop-audit-dashboard__insights-grid">

                        {# ------------------------------------------------------------------ #}
                        {# Top selling products widget: Best-selling product list            #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card esmx-shop-audit-dashboard__widget-card">
                            <div class="esmx-shop-audit-dashboard__widget-header">
                                <div class="esmx-shop-audit-dashboard__widget-header-text">
                                    <div class="esmx-shop-audit-dashboard__widget-title">
                                        {{ $tc('esmx-shop-audit-ai.dashboard.topSellingProducts') }}
                                    </div>
                                    <div class="esmx-shop-audit-dashboard__widget-subtitle">
                                        {{ $tc('esmx-shop-audit-ai.dashboard.topSellingProductsSubtitle') }}
                                    </div>
                                </div>

                                <span
                                        class="esmx-shop-audit-dashboard__widget-info-trigger"
                                        @mouseenter="activeWidgetTooltip = 'topSellingProducts'"
                                        @mouseleave="activeWidgetTooltip = null"
                                >
            <mt-icon
                    name="regular-info-circle"
                    size="16px"
                    class="esmx-shop-audit-dashboard__widget-info-icon"
            />

            <span
                    v-if="activeWidgetTooltip === 'topSellingProducts'"
                    class="esmx-shop-audit-dashboard__widget-tooltip"
            >
                {{ $tc('esmx-shop-audit-ai.dashboard.topSellingProductsInfo') }}
            </span>
        </span>
                            </div>

                            <div class="esmx-shop-audit-dashboard__widget-body">
                                <div v-if="topSellingProducts.length">
                                    <div
                                            v-for="product in topSellingProducts"
                                            :key="product.productId"
                                            class="esmx-shop-audit-dashboard__insight-list-item esmx-shop-audit-dashboard__insight-list-item--clickable"
                                            @click="goToProductDetail(product.productId)"
                                    >
                                        <span>{{ product.name }}</span>
                                        <strong>{{ product.sales }}</strong>
                                    </div>
                                </div>

                                <div v-else>
                                    {{ $tc('esmx-shop-audit-ai.dashboard.noSalesData') }}
                                </div>
                            </div>
                        </mt-card>

                        {# ------------------------------------------------------------------ #}
                        {# Low stock products widget: Products with low available stock      #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card esmx-shop-audit-dashboard__widget-card">
                            <div class="esmx-shop-audit-dashboard__widget-header">
                                <div class="esmx-shop-audit-dashboard__widget-header-text">
                                    <div class="esmx-shop-audit-dashboard__widget-title">
                                        {{ $tc('esmx-shop-audit-ai.dashboard.lowStockProducts') }}
                                    </div>
                                    <div class="esmx-shop-audit-dashboard__widget-subtitle">
                                        {{ $tc('esmx-shop-audit-ai.dashboard.lowStockProductsSubtitle') }}
                                    </div>
                                </div>

                                <span
                                        class="esmx-shop-audit-dashboard__widget-info-trigger"
                                        @mouseenter="activeWidgetTooltip = 'lowStockProducts'"
                                        @mouseleave="activeWidgetTooltip = null"
                                >
            <mt-icon
                    name="regular-info-circle"
                    size="16px"
                    class="esmx-shop-audit-dashboard__widget-info-icon"
            />

            <span
                    v-if="activeWidgetTooltip === 'lowStockProducts'"
                    class="esmx-shop-audit-dashboard__widget-tooltip"
            >
                {{ $tc('esmx-shop-audit-ai.dashboard.lowStockProductsInfo') }}
            </span>
        </span>
                            </div>

                            <div class="esmx-shop-audit-dashboard__widget-body">
                                <div v-if="lowStockProducts.length">
                                    <div
                                            v-for="product in lowStockProducts"
                                            :key="product.id"
                                            class="esmx-shop-audit-dashboard__insight-list-item esmx-shop-audit-dashboard__insight-list-item--clickable"
                                            @click="goToProductDetail(product.id)"
                                    >
                                        <span>{{ product.name }}</span>
                                        <strong>{{ $tc('esmx-shop-audit-ai.dashboard.stockLabel') }}: {{ product.stock }}</strong>
                                    </div>
                                </div>

                                <div v-else>
                                    {{ $tc('esmx-shop-audit-ai.dashboard.noLowStockProducts') }}
                                </div>
                            </div>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Live audit summary section: Header and issue summary cards          #}
                    {# ------------------------------------------------------------------ #}
                    <div class="esmx-shop-audit-dashboard__summary">
                        <div class="esmx-shop-audit-dashboard__summary-meta">
                            <div class="esmx-shop-audit-dashboard__summary-header">
                                <div class="esmx-shop-audit-dashboard__headline">
                                    <h3>{{ cardTitle }}</h3>
                                    <p>
                                        {{ $tc('esmx-shop-audit-ai.dashboard.scannedProducts') }}:
                                        <strong>{{ meta.scannedProducts }}</strong>
                                        ·
                                        {{ $tc('esmx-shop-audit-ai.dashboard.totalIssues') }}:
                                        <strong>{{ totals.totalIssues }}</strong>
                                    </p>
                                </div>

                                <mt-button
                                        size="small"
                                        variant="secondary"
                                        @click="goToFindings"
                                >
                                    {{ $tc('esmx-shop-audit-ai.dashboard.viewAllFindings') }}
                                </mt-button>
                            </div>
                        </div>

                        <div class="esmx-shop-audit-dashboard__summary-grid">
                            <a
                                    v-for="card in sortedSummaryCards"
                                    :key="card.key"
                                    href="#"
                                    class="esmx-shop-audit-dashboard__metric-card-link"
                                    @click.prevent="goToFindingFromCard(card)"
                            >
                                <mt-card
                                        class="esmx-shop-audit-dashboard__metric-card"
                                        :class="getSeverityClass(card.severity)"
                                >
                                    <div class="esmx-shop-audit-dashboard__metric-card-layout">
                                        <div
                                                class="esmx-shop-audit-dashboard__metric-card-count-area"
                                                :class="'severity-' + card.severity"
                                        >
            <span class="esmx-shop-audit-dashboard__metric-card-number">
                {{ card.count }}
            </span>
                                        </div>

                                        <div class="esmx-shop-audit-dashboard__metric-card-details">
                                            <div class="esmx-shop-audit-dashboard__metric-card-title-row">
                                                <div class="esmx-shop-audit-dashboard__metric-card-label">
                                                    {{ card.label }}
                                                </div>
                                            </div>

                                            <div class="esmx-shop-audit-dashboard__metric-card-meta-row">
                <span
                        class="esmx-shop-audit-dashboard__severity-badge"
                        :class="'severity-' + card.severity"
                >
                    {{ getSeverityLabel(card.severity) }}
                </span>
                                                <span
                                                        class="esmx-shop-audit-dashboard__metric-card-info-wrapper"
                                                        @mouseenter="activeImpactKey = card.key"
                                                        @mouseleave="activeImpactKey = null"
                                                >
    <mt-icon
            name="regular-info-circle"
            size="16px"
            class="esmx-shop-audit-dashboard__metric-card-info"
    />

    <span
            v-if="activeImpactKey === card.key"
            class="esmx-shop-audit-dashboard__metric-card-tooltip"
    >
        {{ card.impact }}
    </span>
</span>
                                            </div>
                                        </div>
                                    </div>
                                </mt-card>
                            </a>
                        </div>
                    </div>

                </template>

                {# ------------------------------------------------------------------ #}
                {# Empty state section: Shown when no dashboard data is available       #}
                {# ------------------------------------------------------------------ #}
                <template v-else>
                    <mt-card>
                        <p>{{ $tc('esmx-shop-audit-ai.dashboard.emptyState') }}</p>
                    </mt-card>
                </template>

            </sw-card-view>
        </template>
    </sw-page>
{% endblock %}