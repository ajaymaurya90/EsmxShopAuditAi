{% block esmx_shop_audit_dashboard %}
    <sw-page class="esmx-shop-audit-dashboard">

        {# ------------------------------------------------------------------ #}
        {# Smart bar header section: Main page title                          #}
        {# ------------------------------------------------------------------ #}
        <template #smart-bar-header>
            <h2>{{ $tc('esmx-shop-audit-ai.general.mainMenuItemGeneral') }}</h2>
        </template>

        {# ------------------------------------------------------------------ #}
        {# Smart bar actions section: Navigation + page actions               #}
        {# ------------------------------------------------------------------ #}
        <template #smart-bar-actions>
            <mt-button variant="primary" size="default">
                {{ $tc('esmx-shop-audit-ai.navigation.dashboard') }}
            </mt-button>

            <mt-button size="default" @click="goToFindings">
                {{ $tc('esmx-shop-audit-ai.navigation.findings') }}
            </mt-button>

            <mt-button size="default" @click="goToTasks">
                {{ $tc('esmx-shop-audit-ai.navigation.tasks') }}
            </mt-button>

            <mt-button size="default" @click="goToReports">
                {{ $tc('esmx-shop-audit-ai.navigation.reports') }}
            </mt-button>

            <mt-button size="default" @click="goToSettings">
                {{ $tc('esmx-shop-audit-ai.navigation.settings') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isLoading || isRunningScan"
                    @click="initializeDashboard"
            >
                <span>{{ $tc('esmx-shop-audit-ai.general.refresh') }}</span>
            </mt-button>

            <div class="esmx-shop-audit-dashboard__actions">
                <mt-button
                        variant="primary"
                        size="default"
                        :loading="isRunningScan"
                        :disabled="isRunningScan"
                        @click="runScan"
                >
                    <span v-if="isRunningScan" class="esmx-shop-audit-dashboard__scan-status">
                    {{ $tc('esmx-shop-audit-ai.dashboard.scanRunning') }}
                </span>
                    <span v-else >
                    {{ $tc('esmx-shop-audit-ai.dashboard.scanStart') }}
                </span>
                </mt-button>


            </div>
        </template>

        {# ------------------------------------------------------------------ #}
        {# Main content section: All dashboard widgets and detail grids       #}
        {# ------------------------------------------------------------------ #}
        <template #content>
            <sw-card-view>

                {# ------------------------------------------------------------------ #}
                {# Global page error banner: Display dashboard load error              #}
                {# ------------------------------------------------------------------ #}
                <template v-if="loadError">
                    <mt-banner variant="danger">
                        {{ loadError }}
                    </mt-banner>
                </template>

                {# ------------------------------------------------------------------ #}
                {# Dashboard loaded state: Render all dashboard widgets                #}
                {# ------------------------------------------------------------------ #}
                <template v-else-if="dashboard">

                    {# ------------------------------------------------------------------ #}
                    {# Scan action error banner: Display scan execution error            #}
                    {# ------------------------------------------------------------------ #}
                    <template v-if="scanError">
                        <mt-banner variant="danger">
                            {{ scanError }}
                        </mt-banner>
                    </template>


                    <div class="esmx-shop-audit-dashboard__hero">
                        <div class="esmx-shop-audit-dashboard__hero-text">
                            <h3 class="esmx-shop-audit-dashboard__headline">
                                {{ dashboardHeadline }}
                            </h3>

                            <p
                                    v-if="formattedLatestScanDate"
                                    class="esmx-shop-audit-dashboard__last-scan"
                            >
                                {{ $tc('esmx-shop-audit-ai.dashboard.lastScanLabel') }}: {{ formattedLatestScanDate }}
                            </p>
                        </div>

                        <div
                                v-if="nextBestAction"
                                class="esmx-shop-audit-dashboard__next-action"
                        >
                            <div class="esmx-shop-audit-dashboard__next-action-title">
                                {{ $tc('esmx-shop-audit-ai.dashboard.nextBestActionTitle') }}
                            </div>

                            <div class="esmx-shop-audit-dashboard__next-action-label">
                                {{ nextBestAction.label }}
                            </div>

                            <mt-button
                                    size="small"
                                    variant="primary"
                                    @click="handleNextBestAction"
                            >
                                {{ $tc('esmx-shop-audit-ai.dashboard.reviewNow') }}
                            </mt-button>
                        </div>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Latest scan summary card: Shows latest persisted scan overview    #}
                    {# ------------------------------------------------------------------ #}
                    <mt-card v-if="latestScan" class="esmx-shop-audit-dashboard__latest-scan-card">
                        <template #headline>
                            {{ $tc('esmx-shop-audit-ai.dashboard.latestScanHeadline') }}
                        </template>

                        <div class="esmx-shop-audit-dashboard__latest-scan-meta">
                            <p>
                                {{ $tc('esmx-shop-audit-ai.dashboard.scanStatus') }}:
                                <strong>{{ latestScan.status }}</strong>
                            </p>
                            <p>
                                {{ $tc('esmx-shop-audit-ai.dashboard.scannedProducts') }}:
                                <strong>{{ latestScan.scannedProducts }}</strong>
                            </p>
                            <p>
                                {{ $tc('esmx-shop-audit-ai.dashboard.groupedFindings') }}:
                                <strong>{{ latestScan.totalFindings }}</strong>
                            </p>
                            <p>
                                {{ $tc('esmx-shop-audit-ai.dashboard.highPriorityFindings') }}:
                                <strong>{{ latestScan.highPriorityFindings }}</strong>
                            </p>
                        </div>
                    </mt-card>

                    {# ------------------------------------------------------------------ #}
                    {# Insights widget grid: KPI metrics, top tasks, findings, summary   #}
                    {# ------------------------------------------------------------------ #}
                    <div class="esmx-shop-audit-dashboard__insights-grid">

                        {# ------------------------------------------------------------------ #}
                        {# KPI metrics widget: Open tasks, findings and scanned products    #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card">
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboardInsights.kpiHeadline') }}
                            </template>

                            <div class="esmx-shop-audit-dashboard__kpi-grid">
                                <div class="esmx-shop-audit-dashboard__kpi-item">
                                    <span class="esmx-shop-audit-dashboard__kpi-label">
                                        {{ $tc('esmx-shop-audit-ai.dashboardInsights.openTasks') }}
                                    </span>
                                    <strong class="esmx-shop-audit-dashboard__kpi-value">{{ openTaskCount }}</strong>
                                </div>

                                <div class="esmx-shop-audit-dashboard__kpi-item">
                                    <span class="esmx-shop-audit-dashboard__kpi-label">
                                        {{ $tc('esmx-shop-audit-ai.dashboardInsights.groupedFindings') }}
                                    </span>
                                    <strong class="esmx-shop-audit-dashboard__kpi-value">{{ latestScan?.totalFindings || 0 }}</strong>
                                </div>

                                <div class="esmx-shop-audit-dashboard__kpi-item">
                                    <span class="esmx-shop-audit-dashboard__kpi-label">
                                        {{ $tc('esmx-shop-audit-ai.dashboardInsights.highPriorityFindings') }}
                                    </span>
                                    <strong class="esmx-shop-audit-dashboard__kpi-value">{{ latestScan?.highPriorityFindings || 0 }}</strong>
                                </div>

                                <div class="esmx-shop-audit-dashboard__kpi-item">
                                    <span class="esmx-shop-audit-dashboard__kpi-label">
                                        {{ $tc('esmx-shop-audit-ai.dashboardInsights.scannedProducts') }}
                                    </span>
                                    <strong class="esmx-shop-audit-dashboard__kpi-value">{{ latestScan?.scannedProducts || 0 }}</strong>
                                </div>
                            </div>
                        </mt-card>

                        {# ------------------------------------------------------------------ #}
                        {# Top tasks widget: Click-through list of highest priority tasks   #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card">
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboardInsights.topTasksHeadline') }}
                            </template>

                            <template v-if="topTasks.length">
                                <div
                                        v-for="task in topTasks"
                                        :key="task.id"
                                        class="esmx-shop-audit-dashboard__insight-list-item esmx-shop-audit-dashboard__insight-list-item--clickable"
                                        @click="goToTaskFilter(task)"
                                >
                                    <div>
                                        <div class="esmx-shop-audit-dashboard__insight-title">{{ task.title }}</div>
                                        <div class="esmx-shop-audit-dashboard__insight-meta">
                                            {{ task.priority }} · {{ task.status }}
                                        </div>
                                    </div>
                                    <strong>{{ task.affectedCount }}</strong>
                                </div>
                            </template>

                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboardInsights.emptyTasks') }}</p>
                            </template>
                        </mt-card>

                        {# ------------------------------------------------------------------ #}
                        {# Top findings widget: Click-through list of key findings          #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card">
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboardInsights.topFindingsHeadline') }}
                            </template>

                            <template v-if="topFindings.length">
                                <div
                                        v-for="finding in topFindings"
                                        :key="finding.id"
                                        class="esmx-shop-audit-dashboard__insight-list-item esmx-shop-audit-dashboard__insight-list-item--clickable"
                                        @click="goToFindingFilter(finding)"
                                >
                                    <div>
                                        <div class="esmx-shop-audit-dashboard__insight-title">{{ finding.title }}</div>
                                        <div class="esmx-shop-audit-dashboard__insight-meta">
                                            {{ finding.severity }}
                                        </div>
                                    </div>
                                    <strong>{{ finding.affectedCount }}</strong>
                                </div>
                            </template>

                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboardInsights.emptyFindings') }}</p>
                            </template>
                        </mt-card>

                        {# ------------------------------------------------------------------ #}
                        {# Latest summary widget: Plain-language summary of latest scan      #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card">
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboardInsights.latestSummaryHeadline') }}
                            </template>

                            <template v-if="latestInsightSummary">
                                <div class="esmx-shop-audit-dashboard__summary-text">
                                    {{ $tc('esmx-shop-audit-ai.dashboardInsights.latestSummaryText', 0, {
                                        scannedProducts: latestInsightSummary.scannedProducts,
                                        totalFindings: latestInsightSummary.totalFindings,
                                        taskCount: latestInsightSummary.taskCount
                                    }) }}
                                </div>
                            </template>

                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboardInsights.emptySummary') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Sales insights card: Revenue and order KPI summary                  #}
                    {# ------------------------------------------------------------------ #}
                    <mt-card class="esmx-shop-audit-dashboard__sales-card">
                        <template #headline>
                            Sales Insights (30 days)
                        </template>

                        <div class="esmx-shop-audit-dashboard__sales-kpis">
                            <div class="sales-kpi">
                                <span>Revenue</span>
                                <strong>{{ salesKpis.revenue }}</strong>
                            </div>

                            <div class="sales-kpi">
                                <span>Orders</span>
                                <strong>{{ salesKpis.orders }}</strong>
                            </div>

                            <div class="sales-kpi">
                                <span>Revenue Change</span>
                                <strong>{{ salesKpis.revenueChange.toFixed(1) }}%</strong>
                            </div>

                            <div class="sales-kpi">
                                <span>Orders Change</span>
                                <strong>{{ salesKpis.ordersChange.toFixed(1) }}%</strong>
                            </div>
                        </div>
                    </mt-card>

                    {# ------------------------------------------------------------------ #}
                    {# Sales insight widgets: Top sellers and low stock product overview   #}
                    {# ------------------------------------------------------------------ #}
                    <div class="esmx-shop-audit-dashboard__insights-grid">

                        {# ------------------------------------------------------------------ #}
                        {# Top selling products widget: Best-selling product list            #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card">
                            <template #headline>
                                Top Selling Products
                            </template>

                            <div v-if="topSellingProducts.length">
                                <div
                                        v-for="product in topSellingProducts"
                                        :key="product.productId"
                                        class="esmx-shop-audit-dashboard__insight-list-item"
                                >
                                    <span>{{ product.name }}</span>
                                    <strong>{{ product.sales }}</strong>
                                </div>
                            </div>

                            <div v-else>
                                No sales data available.
                            </div>
                        </mt-card>

                        {# ------------------------------------------------------------------ #}
                        {# Low stock products widget: Products with low available stock      #}
                        {# ------------------------------------------------------------------ #}
                        <mt-card class="esmx-shop-audit-dashboard__insight-card">
                            <template #headline>
                                Low Stock Products
                            </template>

                            <div v-if="lowStockProducts.length">
                                <div
                                        v-for="product in lowStockProducts"
                                        :key="product.id"
                                        class="esmx-shop-audit-dashboard__insight-list-item"
                                >
                                    <span>{{ product.name }}</span>
                                    <strong>Stock: {{ product.stock }}</strong>
                                </div>
                            </div>

                            <div v-else>
                                No low stock products.
                            </div>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Live audit summary section: Header and issue summary cards          #}
                    {# ------------------------------------------------------------------ #}
                    <div class="esmx-shop-audit-dashboard__summary">
                        <div class="esmx-shop-audit-dashboard__summary-meta">
                            <div class="esmx-shop-audit-dashboard__headline">
                                <h3>{{ cardTitle }}</h3>
                                <p>
                                    {{ $tc('esmx-shop-audit-ai.dashboard.scannedProducts') }}:
                                    <strong>{{ meta.scannedProducts }}</strong>
                                    ·
                                    {{ $tc('esmx-shop-audit-ai.dashboard.totalIssues') }}:
                                    <strong>{{ totals.totalIssues }}</strong>
                                </p>
                            </div>
                        </div>

                        <div class="esmx-shop-audit-dashboard__summary-grid">
                            <a
                                    v-for="card in sortedSummaryCards"
                                    :key="card.key"
                                    href="#"
                                    class="esmx-shop-audit-dashboard__metric-card-link"
                                    @click.prevent="scrollToSection(card.target)"
                            >
                                <mt-card
                                        class="esmx-shop-audit-dashboard__metric-card"
                                        :class="getSeverityClass(card.severity)"
                                >
                                    <div class="esmx-shop-audit-dashboard__metric-card-horizontal">
                                        <div class="esmx-shop-audit-dashboard__metric-card-number-box">
                                            <span class="esmx-shop-audit-dashboard__metric-card-number">
                                                {{ card.count }}
                                            </span>
                                        </div>

                                        <div class="esmx-shop-audit-dashboard__metric-card-content">
                                            <div class="esmx-shop-audit-dashboard__metric-card-label">
                                                {{ card.label }}
                                            </div>

                                            <div class="esmx-shop-audit-dashboard__metric-card-footer">
                                                <span
                                                        class="esmx-shop-audit-dashboard__severity-badge"
                                                        :class="'severity-' + card.severity"
                                                >
                                                    {{ getSeverityLabel(card.severity) }}
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </mt-card>
                            </a>
                        </div>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Missing product descriptions                         #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-missing-description"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingDescription') }}</span>
                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
                                        {{ $tc('esmx-shop-audit-ai.severity.medium') }}
                                    </span>
                                </div>
                            </template>

                            <template v-if="issues.missingDescription?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingDescription"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Missing product cover images                        #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-missing-cover-image"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboard.missingCoverImage') }}
                            </template>

                            <template v-if="issues.missingCoverImage?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingCoverImage"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Inactive products                                   #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-inactive-products"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboard.inactiveProducts') }}
                            </template>

                            <template v-if="issues.inactiveProducts?.length">
                                <sw-data-grid
                                        :dataSource="issues.inactiveProducts"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Out of stock products                               #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-out-of-stock-products"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboard.outOfStockProducts') }}
                            </template>

                            <template v-if="issues.outOfStockProducts?.length">
                                <sw-data-grid
                                        :dataSource="issues.outOfStockProducts"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Missing meta titles                                 #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-missing-meta-title"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                {{ $tc('esmx-shop-audit-ai.dashboard.missingMetaTitle') }}
                            </template>

                            <template v-if="issues.missingMetaTitle?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingMetaTitle"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Missing category assignments                        #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-missing-category"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingCategory') }}</span>
                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
                                        {{ $tc('esmx-shop-audit-ai.severity.medium') }}
                                    </span>
                                </div>
                            </template>

                            <template v-if="issues.missingCategory?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingCategory"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Missing manufacturers                               #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-missing-manufacturer"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingManufacturer') }}</span>
                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
                                        {{ $tc('esmx-shop-audit-ai.severity.medium') }}
                                    </span>
                                </div>
                            </template>

                            <template v-if="issues.missingManufacturer?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingManufacturer"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Missing prices                                      #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-missing-price"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingPrice') }}</span>
                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-high">
                                        {{ $tc('esmx-shop-audit-ai.severity.high') }}
                                    </span>
                                </div>
                            </template>

                            <template v-if="issues.missingPrice?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingPrice"
                                        :columns="gridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Missing translations                                #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-missing-translation"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.missingTranslation') }}</span>
                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
                                        {{ $tc('esmx-shop-audit-ai.severity.medium') }}
                                    </span>
                                </div>
                            </template>

                            <template v-if="issues.missingTranslation?.length">
                                <sw-data-grid
                                        :dataSource="issues.missingTranslation"
                                        :columns="translationGridColumns"
                                />
                            </template>
                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </mt-card>
                    </div>

                    {# ------------------------------------------------------------------ #}
                    {# Detail section: Missing product meta descriptions                 #}
                    {# ------------------------------------------------------------------ #}
                    <div
                            id="audit-section-product-missing-meta-description"
                            class="esmx-shop-audit-dashboard__details-section"
                    >
                        <mt-card>
                            <template #headline>
                                <div class="esmx-shop-audit-dashboard__section-header">
                                    <span>{{ $tc('esmx-shop-audit-ai.dashboard.productMissingMetaDescription') }}</span>
                                    <span class="esmx-shop-audit-dashboard__severity-badge severity-medium">
                    {{ $tc('esmx-shop-audit-ai.severity.medium') }}
                </span>
                                </div>
                            </template>

                            <template v-if="issues.product_missing_meta_description?.length">
                                <sw-data-grid
