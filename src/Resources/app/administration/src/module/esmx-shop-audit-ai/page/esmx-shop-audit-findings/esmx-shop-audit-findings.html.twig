{% block esmx_shop_audit_findings %}
    <sw-page class="esmx-shop-audit-findings">
        <template #smart-bar-header>
            <h2>{{ pageTitle }}</h2>
        </template>

        <template #smart-bar-actions>
            <mt-button size="default" @click="goToDashboard">
                {{ $tc('esmx-shop-audit-ai.navigation.dashboard') }}
            </mt-button>

            <mt-button variant="primary" size="default">
                {{ $tc('esmx-shop-audit-ai.navigation.findings') }}
            </mt-button>

            <mt-button size="default" @click="goToTasks">
                {{ $tc('esmx-shop-audit-ai.navigation.tasks') }}
            </mt-button>

            <mt-button size="default" @click="goToReports">
                {{ $tc('esmx-shop-audit-ai.navigation.reports') }}
            </mt-button>

            <mt-button size="default" @click="goToSettings">
                {{ $tc('esmx-shop-audit-ai.navigation.settings') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isLoading || isRunningScan"
                    @click="loadPageData"
            >
                {{ $tc('esmx-shop-audit-ai.general.refresh') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isRunningScan"
                    @click="runScan"
            >
                <span v-if="isRunningScan">{{ $tc('esmx-shop-audit-ai.dashboard.runningScanButton') }}</span>
                <span v-else>{{ $tc('esmx-shop-audit-ai.dashboard.runScanButton') }}</span>
            </mt-button>
        </template>

        <template #content>
            <sw-card-view>
                <template v-if="loadError">
                    <mt-banner variant="danger">
                        {{ loadError }}
                    </mt-banner>
                </template>
                <template v-if="scanError">
                    <mt-banner variant="danger">
                        {{ scanError }}
                    </mt-banner>
                </template>

                <mt-card v-if="latestScan" class="esmx-shop-audit-dashboard__latest-scan-card">
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.findings.latestScanHeadline') }}
                    </template>

                    <div class="esmx-shop-audit-dashboard__latest-scan-meta">
                        <p>
                            {{ $tc('esmx-shop-audit-ai.dashboard.scanStatus') }}:
                            <strong>{{ latestScan.status }}</strong>
                        </p>
                        <p>
                            {{ $tc('esmx-shop-audit-ai.dashboard.groupedFindings') }}:
                            <strong>{{ latestScan.totalFindings }}</strong>
                        </p>
                        <p>
                            {{ $tc('esmx-shop-audit-ai.dashboard.highPriorityFindings') }}:
                            <strong>{{ latestScan.highPriorityFindings }}</strong>
                        </p>
                    </div>
                </mt-card>

                <mt-card>
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.findings.gridHeadline') }}
                    </template>

                    <template v-if="findings.length">
                        <sw-data-grid
                                :dataSource="findings"
                                :columns="columns"
                        />
                    </template>

                    <template v-else>
                        <p>{{ $tc('esmx-shop-audit-ai.findings.emptyState') }}</p>
                    </template>
                </mt-card>
            </sw-card-view>
        </template>
    </sw-page>
{% endblock %}