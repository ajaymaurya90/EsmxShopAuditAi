{% block esmx_shop_audit_findings %}
    <sw-page class="esmx-shop-audit esmx-shop-audit-findings">
        <template #smart-bar-header>
            <h2>{{ pageTitle }}</h2>
        </template>

        <template #smart-bar-actions>
            <mt-button size="default" @click="goToDashboard">
                {{ $tc('esmx-shop-audit-ai.navigation.dashboard') }}
            </mt-button>

            <mt-button variant="primary" size="default">
                {{ $tc('esmx-shop-audit-ai.navigation.findings') }}
            </mt-button>

            <mt-button size="default" @click="goToTasks">
                {{ $tc('esmx-shop-audit-ai.navigation.tasks') }}
            </mt-button>

            <mt-button size="default" @click="goToReports">
                {{ $tc('esmx-shop-audit-ai.navigation.reports') }}
            </mt-button>

            <mt-button size="default" @click="goToSettings">
                {{ $tc('esmx-shop-audit-ai.navigation.settings') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isLoading || isRunningScan"
                    @click="loadPageData"
            >
                {{ $tc('esmx-shop-audit-ai.general.refresh') }}
            </mt-button>

            <div class="esmx-shop-audit-dashboard__actions">
                <mt-button
                        variant="primary"
                        size="default"
                        :loading="isRunningScan"
                        :disabled="isRunningScan"
                        @click="runScan"
                >
                    <span v-if="isRunningScan" class="esmx-shop-audit-dashboard__scan-status">
                        {{ $tc('esmx-shop-audit-ai.dashboard.scanRunning') }}
                    </span>
                    <span v-else>
                        {{ $tc('esmx-shop-audit-ai.dashboard.scanStart') }}
                    </span>
                </mt-button>
            </div>
        </template>

        <template #content>
            <sw-card-view class="esmx-shop-audit__page-view">
                <template v-if="loadError">
                    <mt-banner variant="danger">
                        {{ loadError }}
                    </mt-banner>
                </template>

                <template v-if="scanError">
                    <mt-banner variant="danger">
                        {{ scanError }}
                    </mt-banner>
                </template>

                <mt-card class="esmx-shop-audit__overview-card">
                    <div class="esmx-shop-audit__section-header">
                        <div class="esmx-shop-audit__section-title">
                            {{ $tc('esmx-shop-audit-ai.findings.overviewTitle') }}
                        </div>

                        <div class="esmx-shop-audit__section-header-meta">
                            <div
                                    v-if="latestScan && latestScan.finishedAt"
                                    class="esmx-shop-audit__section-subtitle"
                            >
                                {{ $tc('esmx-shop-audit-ai.dashboard.lastScanLabel') }}: {{ formatDate(latestScan.finishedAt) }}
                            </div>

                            <span
                                    class="esmx-shop-audit__info-trigger"
                                    @mouseenter="activeWidgetTooltip = 'findingsOverview'"
                                    @mouseleave="activeWidgetTooltip = null"
                            >
                                <mt-icon
                                        name="regular-info-circle"
                                        size="16px"
                                        class="esmx-shop-audit__info-icon"
                                />

                                <span
                                        v-if="activeWidgetTooltip === 'findingsOverview'"
                                        class="esmx-shop-audit__tooltip"
                                >
                                    {{ $tc('esmx-shop-audit-ai.findings.overviewTooltip') }}
                                </span>
                            </span>
                        </div>
                    </div>

                    <div class="esmx-shop-audit__stats-strip">
                        <div class="esmx-shop-audit__stat-item">
                            <div class="esmx-shop-audit__stat-label">{{ $tc('esmx-shop-audit-ai.findings.stats.totalFindings') }}</div>
                            <div class="esmx-shop-audit__stat-value">{{ findings.length }}</div>
                        </div>

                        <div class="esmx-shop-audit__stat-item">
                            <div class="esmx-shop-audit__stat-label">{{ $tc('esmx-shop-audit-ai.severity.critical') }}</div>
                            <div class="esmx-shop-audit__stat-value">{{ findingsBySeverity.critical }}</div>
                        </div>

                        <div class="esmx-shop-audit__stat-item">
                            <div class="esmx-shop-audit__stat-label">{{ $tc('esmx-shop-audit-ai.severity.high') }}</div>
                            <div class="esmx-shop-audit__stat-value">{{ findingsBySeverity.high }}</div>
                        </div>

                        <div class="esmx-shop-audit__stat-item">
                            <div class="esmx-shop-audit__stat-label">{{ $tc('esmx-shop-audit-ai.severity.medium') }}</div>
                            <div class="esmx-shop-audit__stat-value">{{ findingsBySeverity.medium }}</div>
                        </div>

                        <div class="esmx-shop-audit__stat-item">
                            <div class="esmx-shop-audit__stat-label">{{ $tc('esmx-shop-audit-ai.severity.low') }}</div>
                            <div class="esmx-shop-audit__stat-value">{{ findingsBySeverity.low }}</div>
                        </div>

                        <div class="esmx-shop-audit__stat-item">
                            <div class="esmx-shop-audit__stat-label">{{ $tc('esmx-shop-audit-ai.findings.stats.affectedItems') }}</div>
                            <div class="esmx-shop-audit__stat-value">{{ totalAffectedCount }}</div>
                        </div>
                    </div>
                </mt-card>

                <mt-card class="esmx-shop-audit__table-card">
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.findings.gridHeadline') }}
                    </template>

                    <div v-if="sortedFindings.length" class="esmx-shop-audit-findings__table">
                        <div class="esmx-shop-audit-findings__table-sticky-top">
                            <div class="esmx-shop-audit__table-topbar">
                                <div class="esmx-shop-audit__table-meta">
                                    {{ resultsSummaryText }}
                                </div>

                                <div class="esmx-shop-audit__filters-toolbar">
                                    <div class="esmx-shop-audit__filter-dropdown-wrapper">
                                        <button
                                                type="button"
                                                class="esmx-shop-audit__filter-dropdown-trigger"
                                                @click="toggleFilterMenu"
                                        >
                                            <mt-icon name="regular-filter" size="16px" />
                                            <span>{{ $tc('esmx-shop-audit-ai.findings.filterSeverity') }}</span>

                                            <span
                                                    v-if="selectedSeverityFilters.length"
                                                    class="esmx-shop-audit__filter-count"
                                            >
                                                {{ selectedSeverityFilters.length }}
                                            </span>
                                        </button>

                                        <div
                                                v-if="isFilterMenuOpen"
                                                class="esmx-shop-audit__filter-dropdown-menu"
                                        >
                                            <label
                                                    v-for="filter in severityFilters"
                                                    :key="filter.key"
                                                    class="esmx-shop-audit__filter-option"
                                                    :class="{ 'is-disabled': filter.disabled }"
                                            >
                                                <input
                                                        type="checkbox"
                                                        :checked="isSeveritySelected(filter.key)"
                                                        :disabled="filter.disabled"
                                                        @change="toggleSeverityFilter(filter.key)"
                                                >
                                                <span>{{ filter.label }} ({{ filter.count }})</span>
                                            </label>
                                        </div>
                                    </div>

                                    <button
                                            type="button"
                                            class="esmx-shop-audit__clear-filter-button"
                                            :disabled="!selectedSeverityFilters.length"
                                            @click="clearSeverityFilters"
                                    >
                                        <mt-icon name="regular-times-s" size="16px" />
                                    </button>
                                </div>
                            </div>

                            <div class="esmx-shop-audit-findings__table-header">
                                <button
                                        type="button"
                                        class="esmx-shop-audit-findings__header-button esmx-shop-audit-findings__col esmx-shop-audit-findings__col--title"
                                        @click="toggleSort('title')"
                                >
                                    <span>{{ $tc('esmx-shop-audit-ai.findings.columns.title') }}</span>
                                    <mt-icon
                                            v-if="isSortedBy('title')"
                                            :name="sortIconMap[sortDirection]"
                                            size="16px"
                                    />
                                </button>

                                <button
                                        type="button"
                                        class="esmx-shop-audit-findings__header-button esmx-shop-audit-findings__col esmx-shop-audit-findings__col--category"
                                        @click="toggleSort('category')"
                                >
                                    <span>{{ $tc('esmx-shop-audit-ai.findings.columns.category') }}</span>
                                    <mt-icon
                                            v-if="isSortedBy('category')"
                                            :name="sortIconMap[sortDirection]"
                                            size="16px"
                                    />
                                </button>

                                <button
                                        type="button"
                                        class="esmx-shop-audit-findings__header-button esmx-shop-audit-findings__col esmx-shop-audit-findings__col--severity"
                                        @click="toggleSort('severity')"
                                >
                                    <span>{{ $tc('esmx-shop-audit-ai.findings.columns.severity') }}</span>
                                    <mt-icon
                                            v-if="isSortedBy('severity')"
                                            :name="sortIconMap[sortDirection]"
                                            size="16px"
                                    />
                                </button>

                                <button
                                        type="button"
                                        class="esmx-shop-audit-findings__header-button esmx-shop-audit-findings__col esmx-shop-audit-findings__col--count"
                                        @click="toggleSort('count')"
                                >
                                    <span>{{ $tc('esmx-shop-audit-ai.findings.columns.affectedCount') }}</span>
                                    <mt-icon
                                            v-if="isSortedBy('count')"
                                            :name="sortIconMap[sortDirection]"
                                            size="16px"
                                    />
                                </button>

                                <div class="esmx-shop-audit-findings__col esmx-shop-audit-findings__col--action">
                                    {{ $tc('esmx-shop-audit-ai.findings.columns.action') }}
                                </div>
                            </div>
                        </div>

                        <div class="esmx-shop-audit-findings__table-body">
                            <div
                                    v-for="finding in sortedFindings"
                                    :key="finding.id"
                                    class="esmx-shop-audit-findings__table-row"
                            >
                                <div class="esmx-shop-audit-findings__col esmx-shop-audit-findings__col--title">
                                    <div class="esmx-shop-audit-findings__row-label">
                                        {{ $tc('esmx-shop-audit-ai.findings.columns.title') }}
                                    </div>
                                    <div class="esmx-shop-audit-findings__cell-title">
                                        {{ finding.title }}
                                    </div>
                                </div>

                                <div class="esmx-shop-audit-findings__col esmx-shop-audit-findings__col--category">
                                    <div class="esmx-shop-audit-findings__row-label">
                                        {{ $tc('esmx-shop-audit-ai.findings.columns.category') }}
                                    </div>
                                    <div>{{ getCategoryLabel(finding.entity) }}</div>
                                </div>

                                <div class="esmx-shop-audit-findings__col esmx-shop-audit-findings__col--severity">
                                    <div class="esmx-shop-audit-findings__row-label">
                                        {{ $tc('esmx-shop-audit-ai.findings.columns.severity') }}
                                    </div>
                                    <span
                                            class="esmx-shop-audit-findings__severity-badge"
                                            :class="getSeverityClass(finding.severity)"
                                    >
                                        {{ getSeverityLabel(finding.severity) }}
                                    </span>
                                </div>

                                <div class="esmx-shop-audit-findings__col esmx-shop-audit-findings__col--count">
                                    <div class="esmx-shop-audit-findings__row-label">
                                        {{ $tc('esmx-shop-audit-ai.findings.columns.affectedCount') }}
                                    </div>
                                    <strong>{{ finding.affectedCount }}</strong>
                                </div>

                                <div class="esmx-shop-audit-findings__col esmx-shop-audit-findings__col--action">
                                    <div class="esmx-shop-audit-findings__row-label">
                                        {{ $tc('esmx-shop-audit-ai.findings.columns.action') }}
                                    </div>

                                    <div class="esmx-shop-audit-findings__action-group">
                                        <span
                                                class="esmx-shop-audit-findings__impact-trigger"
                                                @mouseenter="activeImpactCode = finding.code"
                                                @mouseleave="activeImpactCode = null"
                                        >
                                            <mt-icon
                                                    name="regular-info-circle"
                                                    size="16px"
                                                    class="esmx-shop-audit-findings__impact-icon"
                                            />

                                            <span
                                                    v-if="activeImpactCode === finding.code"
                                                    class="esmx-shop-audit-findings__impact-tooltip"
                                            >
                                                {{ getImpactLabel(finding.code) }}
                                            </span>
                                        </span>

                                        <mt-button
                                                size="small"
                                                variant="secondary"
                                                @click="goToFindingDetailSection(finding)"
                                        >
                                            <mt-icon name="regular-eye" size="16px" />
                                        </mt-button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div v-else class="esmx-shop-audit-findings__empty-state">
                        <p v-if="hasActiveFilters">
                            {{ $tc('esmx-shop-audit-ai.findings.emptyFilteredState') }}
                        </p>
                        <p v-else>
                            {{ $tc('esmx-shop-audit-ai.findings.emptyState') }}
                        </p>
                    </div>
                </mt-card>

                <div
                        v-for="finding in sortedFindings"
                        :key="`section-${finding.id}`"
                        :id="`finding-section-${finding.code}`"
                        class="esmx-shop-audit-findings__detail-section"
                >
                    <mt-card class="esmx-shop-audit-findings__detail-card">
                        <div class="esmx-shop-audit-findings__detail-header">
                            <div class="esmx-shop-audit-findings__detail-header-main">
                                <div class="esmx-shop-audit-findings__detail-title">
                                    {{ finding.title }}
                                </div>
                                <div class="esmx-shop-audit-findings__detail-meta">
                                    {{ finding.entity }} · {{ finding.affectedCount }} {{ $tc('esmx-shop-audit-ai.findings.affectedItems') }}
                                </div>
                            </div>

                            <span
                                    class="esmx-shop-audit-findings__severity-badge"
                                    :class="getSeverityClass(finding.severity)"
                            >
                                {{ getSeverityLabel(finding.severity) }}
                            </span>
                        </div>

                        <div class="esmx-shop-audit-findings__detail-body">
                            <template v-if="finding.items?.length">
                                <sw-data-grid
                                        :dataSource="getPaginatedFindingItems(finding)"
                                        :columns="[
                                        { property: 'name', label: $tc('esmx-shop-audit-ai.grid.productName'), primary: true },
                                        { property: 'productNumber', label: $tc('esmx-shop-audit-ai.grid.productNumber') },
                                        { property: 'stock', label: $tc('esmx-shop-audit-ai.grid.stock') }
                                    ]"
                                        :showSelection="false"
                                        :showActions="true"
                                >
                                    <template #actions="{ item }">
                                        <sw-context-menu-item @click="openProductDetailInNewTab(item)">
                                            {{ $tc('esmx-shop-audit-ai.findings.viewDetail') }}
                                        </sw-context-menu-item>
                                    </template>
                                </sw-data-grid>

                                <div
                                        v-if="getDetailTotalPages(finding) > 1"
                                        class="esmx-shop-audit-findings__detail-pagination"
                                >
                                    <div class="esmx-shop-audit-findings__detail-pagination-meta">
                                        {{ $tc('esmx-shop-audit-ai.findings.pageLabel') }}
                                        <strong>{{ getDetailCurrentPage(finding.id) }}</strong>
                                        {{ $tc('esmx-shop-audit-ai.findings.ofLabel') }}
                                        <strong>{{ getDetailTotalPages(finding) }}</strong>
                                    </div>

                                    <div class="esmx-shop-audit-findings__detail-pagination-actions">
                                        <mt-button
                                                size="small"
                                                variant="secondary"
                                                :disabled="getDetailCurrentPage(finding.id) <= 1"
                                                @click="goToDetailPrevPage(finding)"
                                        >
                                            {{ $tc('esmx-shop-audit-ai.findings.previousPage') }}
                                        </mt-button>

                                        <mt-button
                                                size="small"
                                                variant="secondary"
                                                :disabled="getDetailCurrentPage(finding.id) >= getDetailTotalPages(finding)"
                                                @click="goToDetailNextPage(finding)"
                                        >
                                            {{ $tc('esmx-shop-audit-ai.findings.nextPage') }}
                                        </mt-button>
                                    </div>
                                </div>
                            </template>

                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.findings.noEntries') }}</p>
                            </template>
                        </div>
                    </mt-card>
                </div>
            </sw-card-view>
        </template>
    </sw-page>
{% endblock %}