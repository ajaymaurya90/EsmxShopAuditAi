{% block esmx_shop_audit_findings %}
    <sw-page class="esmx-shop-audit-findings">
        <template #smart-bar-header>
            <h2>{{ pageTitle }}</h2>
        </template>

        <template #smart-bar-actions>
            <mt-button size="default" @click="goToDashboard">
                {{ $tc('esmx-shop-audit-ai.navigation.dashboard') }}
            </mt-button>

            <mt-button variant="primary" size="default">
                {{ $tc('esmx-shop-audit-ai.navigation.findings') }}
            </mt-button>

            <mt-button size="default" @click="goToTasks">
                {{ $tc('esmx-shop-audit-ai.navigation.tasks') }}
            </mt-button>

            <mt-button size="default" @click="goToReports">
                {{ $tc('esmx-shop-audit-ai.navigation.reports') }}
            </mt-button>

            <mt-button size="default" @click="goToSettings">
                {{ $tc('esmx-shop-audit-ai.navigation.settings') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isLoading || isRunningScan"
                    @click="loadPageData"
            >
                {{ $tc('esmx-shop-audit-ai.general.refresh') }}
            </mt-button>

            <mt-button
                    variant="primary"
                    size="default"
                    :disabled="isRunningScan"
                    @click="runScan"
            >
                <span v-if="isRunningScan">{{ $tc('esmx-shop-audit-ai.dashboard.runningScanButton') }}</span>
                <span v-else>{{ $tc('esmx-shop-audit-ai.dashboard.runScanButton') }}</span>
            </mt-button>
        </template>

        <template #content>
            <sw-card-view>
                <template v-if="loadError">
                    <mt-banner variant="danger">
                        {{ loadError }}
                    </mt-banner>
                </template>

                <template v-if="scanError">
                    <mt-banner variant="danger">
                        {{ scanError }}
                    </mt-banner>
                </template>

                <mt-card v-if="activeCodeFilter" class="esmx-shop-audit-dashboard__latest-scan-card">
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.findings.activeFilterHeadline') }}
                    </template>

                    <div class="esmx-shop-audit-dashboard__latest-scan-meta">
                        <p>
                            Code:
                            <strong>{{ activeCodeFilter }}</strong>
                        </p>
                    </div>

                    <div style="margin-top: 12px;">
                        <mt-button size="default" @click="clearFilters">
                            {{ $tc('esmx-shop-audit-ai.general.clearFilters') }}
                        </mt-button>
                    </div>
                </mt-card>

                <mt-card>
                    <template #headline>
                        {{ $tc('esmx-shop-audit-ai.findings.gridHeadline') }}
                    </template>

                    <template v-if="findings.length">
                        <div
                                v-for="finding in findings"
                                :key="finding.id"
                                class="esmx-shop-audit-dashboard__insight-list-item esmx-shop-audit-dashboard__insight-list-item--clickable"
                                @click="goToFindingDetailSection(finding)"
                        >
                            <div>
                                <div class="esmx-shop-audit-dashboard__insight-title">
                                    {{ finding.title }}
                                </div>
                                <div class="esmx-shop-audit-dashboard__insight-meta">
                                    {{ finding.entity }} ·
                                    <span
                                            class="esmx-shop-audit-dashboard__severity-badge"
                                            :class="getSeverityClass(finding.severity)"
                                    >
                                        {{ getSeverityLabel(finding.severity) }}
                                    </span>
                                </div>
                            </div>
                            <strong>{{ finding.affectedCount }}</strong>
                        </div>
                    </template>

                    <template v-else>
                        <p>{{ $tc('esmx-shop-audit-ai.findings.emptyState') }}</p>
                    </template>
                </mt-card>

                <div
                        v-for="finding in findings"
                        :key="`section-${finding.id}`"
                        :id="`finding-section-${finding.code}`"
                        class="esmx-shop-audit-dashboard__details-section"
                >
                    <mt-card class="esmx-shop-audit-findings__detail-card">
                        <div class="esmx-shop-audit-findings__detail-header">
                            <div class="esmx-shop-audit-findings__detail-header-main">
                                <div class="esmx-shop-audit-findings__detail-title">
                                    {{ finding.title }}
                                </div>
                                <div class="esmx-shop-audit-findings__detail-meta">
                                    {{ finding.entity }} · {{ finding.affectedCount }} {{ $tc('esmx-shop-audit-ai.findings.affectedItems') }}
                                </div>
                            </div>

                            <span
                                    class="esmx-shop-audit-dashboard__severity-badge"
                                    :class="getSeverityClass(finding.severity)"
                            >
            {{ getSeverityLabel(finding.severity) }}
        </span>
                        </div>

                        <div class="esmx-shop-audit-findings__detail-body">
                            <template v-if="finding.items?.length">
                                <sw-data-grid
                                        :dataSource="finding.items"
                                        :columns="[
                    { property: 'name', label: $tc('esmx-shop-audit-ai.grid.productName'), primary: true },
                    { property: 'productNumber', label: $tc('esmx-shop-audit-ai.grid.productNumber') },
                    { property: 'stock', label: $tc('esmx-shop-audit-ai.grid.stock') }
                ]"
                                />
                            </template>

                            <template v-else>
                                <p>{{ $tc('esmx-shop-audit-ai.dashboard.noEntries') }}</p>
                            </template>
                        </div>
                    </mt-card>
                </div>
            </sw-card-view>
        </template>
    </sw-page>
{% endblock %}