<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false" />

        <service id="EsmxShopAuditAi\Core\Content\Scan\ScanDefinition">
            <tag name="shopware.entity.definition" entity="esmx_shop_audit_scan" />
        </service>

        <service id="EsmxShopAuditAi\Core\Content\Scan\Aggregate\Finding\FindingDefinition">
            <tag name="shopware.entity.definition" entity="esmx_shop_audit_finding" />
        </service>

        <service id="EsmxShopAuditAi\Core\Content\Scan\Aggregate\Task\TaskDefinition">
            <tag name="shopware.entity.definition" entity="esmx_shop_audit_task" />
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\ProductAuditService">
            <argument type="service" id="product.repository" />
            <argument type="service" id="language.repository" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
        </service>

        <service id="EsmxShopAuditAi\Service\Scan\FindingBuilder" />

        <service id="EsmxShopAuditAi\Service\Scan\TaskBuilder" />

        <service id="EsmxShopAuditAi\Service\Scan\ManualScanRunner">
            <argument type="service" id="EsmxShopAuditAi\Service\Audit\ProductAuditService" />
            <argument type="service" id="EsmxShopAuditAi\Service\Audit\Seo\SeoAuditService" />
            <argument type="service" id="EsmxShopAuditAi\Service\Scan\FindingBuilder" />
            <argument type="service" id="EsmxShopAuditAi\Service\Scan\TaskBuilder" />
            <argument type="service" id="esmx_shop_audit_scan.repository" />
            <argument type="service" id="esmx_shop_audit_finding.repository" />
            <argument type="service" id="esmx_shop_audit_task.repository" />
            <argument type="service" id="logger" />
        </service>

        <service id="EsmxShopAuditAi\Service\Task\TaskAutoFixService" public="false">
            <argument type="service" id="esmx_shop_audit_task.repository"/>
            <argument type="service" id="esmx_shop_audit_finding.repository"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="logger"/>
        </service>

        <service id="EsmxShopAuditAi\Controller\Admin\AuditDashboardController" public="true">
            <argument type="service" id="EsmxShopAuditAi\Service\Audit\ProductAuditService" />
            <argument type="service" id="EsmxShopAuditAi\Service\Scan\ManualScanRunner" />
            <argument type="service" id="EsmxShopAuditAi\Service\Insights\Sales\SalesInsightService" />
            <argument type="service" id="EsmxShopAuditAi\Service\Audit\Seo\SeoAuditService" />
            <argument type="service" id="esmx_shop_audit_scan.repository" />
            <argument type="service" id="esmx_shop_audit_finding.repository" />
            <argument type="service" id="esmx_shop_audit_task.repository" />
            <argument type="service" id="EsmxShopAuditAi\Service\Task\TaskAutoFixService" />
            <tag name="controller.service_arguments" />
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\Seo\ProductSeoAuditDataProvider">
            <argument type="service" id="product.repository" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <argument type="service" id="logger"/>
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\Seo\SeoAuditService">
            <argument type="service" id="EsmxShopAuditAi\Service\Audit\Seo\ProductSeoAuditDataProvider" />
            <argument type="service" id="logger" />
            <argument type="tagged_iterator" tag="esmx_shop_audit_ai.seo_rule" />
        </service>

        <service id="EsmxShopAuditAi\Service\Insights\Sales\SalesInsightService">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="order_line_item.repository"/>
            <argument type="service" id="product.repository"/>
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\Seo\Rule\ProductMissingMetaDescriptionRule">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <tag name="esmx_shop_audit_ai.seo_rule" />
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\Seo\Rule\ProductWeakTitleRule">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <tag name="esmx_shop_audit_ai.seo_rule" />
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\Seo\Rule\ProductShortDescriptionRule">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <tag name="esmx_shop_audit_ai.seo_rule" />
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\Seo\Rule\CategoryMissingMetaTitleRule">
            <argument type="service" id="category.repository" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <tag name="esmx_shop_audit_ai.seo_rule" />
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\Seo\Rule\CategoryMissingMetaDescriptionRule">
            <argument type="service" id="category.repository" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <tag name="esmx_shop_audit_ai.seo_rule" />
        </service>

        <service id="EsmxShopAuditAi\Service\Audit\Seo\Rule\CategoryMissingDescriptionRule">
            <argument type="service" id="category.repository" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <tag name="esmx_shop_audit_ai.seo_rule" />
        </service>


    </services>
</container>