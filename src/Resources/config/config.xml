<?xml version="1.0" encoding="UTF-8"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">


    <card>
        <title>General settings</title>
        <title lang="de-DE">Allgemeine Einstellungen</title>

        <input-field type="bool">
            <name>enableAudit</name>
            <label>Enable audit checks</label>
            <label lang="de-DE">Audit-Prüfungen aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="int">
            <name>auditProductLimit</name>
            <label>Product audit limit per run</label>
            <label lang="de-DE">Produktlimit pro Audit-Lauf</label>
            <defaultValue>100</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Esmx Shop Audit AI</title>
        <title lang="de-DE">Esmx Shop Audit AI</title>

        <input-field type="single-select">
            <name>variantAuditMode</name>

            <label>Variant audit mode</label>
            <label lang="de-DE">Modus für Variantenprüfung</label>
            <options>
                <option>
                    <id>effective</id>
                    <name>Audit effective storefront data</name>
                    <name lang="de-DE">Effektive Storefront-Daten prüfen</name>
                </option>
                <option>
                    <id>raw</id>
                    <name>Audit raw variant records</name>
                    <name lang="de-DE">Rohe Varianten-Datensätze prüfen</name>
                </option>
            </options>
            <defaultValue>effective</defaultValue>

            <helpText>
                Choose whether the audit should evaluate the effective storefront data inherited from parent products, or strictly check the raw values stored on variant records.
            </helpText>
            <helpText lang="de-DE">
                Wählen Sie, ob das Audit die effektiven Storefront-Daten inklusive Vererbung vom Elternprodukt prüfen soll oder strikt die rohen Werte der Varianten-Datensätze.
            </helpText>
        </input-field>
    </card>

    <card>
        <title>Scan options</title>
        <title lang="de-DE">Scan-Optionen</title>

        <input-field type="bool">
            <name>checkMissingManufacturer</name>
            <label>Check missing manufacturer</label>
            <label lang="de-DE">Fehlenden Hersteller prüfen</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>checkMissingTranslations</name>
            <label>Check missing translations</label>
            <label lang="de-DE">Fehlende Übersetzungen prüfen</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>checkSeoFields</name>
            <label>Check SEO fields</label>
            <label lang="de-DE">SEO-Felder prüfen</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>checkProductMetaDescription</name>
            <label>Check missing product meta description</label>
            <label lang="de-DE">Fehlende Produkt-Meta-Description prüfen</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>checkWeakProductTitle</name>
            <label>Check weak product title</label>
            <label lang="de-DE">Schwachen Produkttitel prüfen</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="int">
            <name>minProductTitleLength</name>
            <label>Minimum product title length</label>
            <label lang="de-DE">Minimale Länge des Produkttitels</label>
            <defaultValue>20</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>checkShortProductDescription</name>
            <label>Check short product description</label>
            <label lang="de-DE">Kurze Produktbeschreibung prüfen</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="int">
            <name>minProductDescriptionLength</name>
            <label>Minimum product description length</label>
            <label lang="de-DE">Minimale Länge der Produktbeschreibung</label>
            <defaultValue>80</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>checkCategorySeo</name>
            <label>Check category SEO fields</label>
            <label lang="de-DE">Kategorie-SEO-Felder prüfen</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

</config>
